<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wishlist_list_tree" model="ir.ui.view">
        <field name="name">wishlist.list.tree</field>
        <field name="model">wishlist.list</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="co_parent_id"/>
                <field name="event_date"/>
                <field name="state"/>
                <field name="public_url"/>
            </list>
        </field>
    </record>

    <record id="view_wishlist_list_form" model="ir.ui.view">
        <field name="name">wishlist.list.form</field>
        <field name="model">wishlist.list</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_active" type="object" string="Activar" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_set_closed" type="object" string="Cerrar" class="btn-secondary" invisible="state != 'active'"/>
                    <button name="action_set_draft" type="object" string="Borrador" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="state == 'closed'"/>
                            <field name="customer_id" readonly="state == 'closed'"/>
                            <field name="co_parent_id" readonly="state == 'closed'"/>
                            <field name="event_date" readonly="state == 'closed'"/>
                        </group>
                        <group>
                            <field name="public_url" readonly="1"/>
                            <field name="token" readonly="1"/>
                            <field name="manage_url" readonly="1"/>
                            <field name="manage_token" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" readonly="state == 'closed'"/>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="line_ids" readonly="state == 'closed'">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity_desired"/>
                                    <field name="quantity_purchased" readonly="1"/>
                                    <field name="remaining_qty" readonly="1"/>
                                    <field name="priority"/>
                                    <field name="notes"/>
                                    <field name="is_fulfilled" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_wishlist_list" model="ir.actions.act_window">
        <field name="name">Baby Wishlists</field>
        <field name="res_model">wishlist.list</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_wishlist_root" name="Baby Wishlist" parent="sale.sale_menu_root" sequence="90"/>
    <menuitem id="menu_wishlist_list" name="Wishlists" parent="menu_wishlist_root" action="action_wishlist_list" sequence="10"/>
</odoo>
